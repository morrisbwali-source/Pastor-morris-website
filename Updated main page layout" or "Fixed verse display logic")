<!-- NEW MOBILE MONEY PAYMENT SECTION -->
<section class="payment-form">
<h2>💳 Airtel Mobile Money Offering</h2>
<p>Support the ministry directly via Airtel Money.</p>
<form action="/api/make-payment" method="POST"> 
    <label for="amount">Donation Amount (ZMW):</label><br>
    <input type="number" id="amount" name="amount" min="1" step="0.01" required><br><br>
    
    <label for="phone">Your Phone Number (e.g., 0976...):</label><br>
    <input type="tel" id="phone" name="phone" pattern="[0-9]{9,15}" required><br><br>
    
    <button type="submit" class="button">Submit Offering</button>
</form>
</section>
<!-- END OF NEW SECTION -->


<section class="registration-form">
<h2>Church Member Registration</h2>
<p>Join our community securely.</p>
<form action="/api/register" method="POST"> 
    <label for="name">Full Name:</label><br>
    <input type="text" id="name" name="name" required><br><br>
    
    <label for="email">Email:</label><br>
    <input type="email" id="email" name="email" required><br><br>
    
    <label for="password">Password:</label><br>
    <input type="password" id="password" name="password" required><br><br>
    
    <button type="submit" class="button">Register Now</button>
</form>
</section>


<section>

<h2>Prayer Request</h2>

<a class="button"
href="[https://wa.me/260976328080?text=Pastor%20please%20pray%20for%20me](https://wa.me/260976328080?text=Pastor%20please%20pray%20for%20me)">
Send Prayer Request
</a>

</section>

